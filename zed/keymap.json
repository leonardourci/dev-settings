// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    // File Explorer bindings
    {
        "context": "ProjectPanel",
        "bindings": {
            "cmd-shift-e": "workspace::ToggleLeftDock", // Focus file explorer and collapse folders
            "space": "project_panel::Open", // Open file with space
            "cmd-n": "project_panel::NewFile",
            "cmd-shift-n": "project_panel::NewDirectory", // New folder
            "up": "menu::SelectPrevious",
            "down": "menu::SelectNext",
            "left": "menu::SelectParent",
            "right": "menu::SelectChild",
            "enter": "project_panel::Open",
        },
    },
    // Source Control / Git bindings
    {
        "context": "Workspace",
        "bindings": {
            "cmd-s": "workspace::Save",
            "cmd-shift-g": "workspace::ToggleRightDock", // Open source control view
            "cmd-shift-b": "workspace::ToggleRightDock", // Toggle auxiliary/right sidebar
            "cmd-g": "go_to_line::Toggle", // Go to line
            "cmd-l": "agent::ToggleFocus", // Open AI assistant,
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "cmd-shift-h": "search::ToggleReplace", // Find and replace
            "cmd-shift-i": "editor::Format", // Format document/selection
            // Trigger suggestions
            "cmd-y": "editor::Redo", // Redo
            "cmd-down": "editor::MoveLineDown", // Move line down
            "cmd-up": "editor::MoveLineUp", // Move line up
            "cmd-r cmd-r": "editor::Rename", // Rename symbol (using chord)
            "alt-g alt-d": "editor::GoToDefinition", // Go to definition
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "shift-alt-up": "editor::MoveToBeginningOfLine", // Jumpy-like behavior (approximate)
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "cmd-shift-g": "git_panel::ToggleFocus",
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-space": "editor::ShowCompletions",
        },
    },
    {
        "context": "vim_mode == insert",
        "bindings": {
            "ctrl-space": "editor::ShowCompletions",
        },
    },
    {
        "context": "vim_mode == insert",
        "bindings": {
            "ctrl-space": "editor::ShowCompletions",
        },
    },
]
